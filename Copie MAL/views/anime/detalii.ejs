<!DOCTYPE html>
<html>
<head>
    <title><%= anime.titlu %> - WeebHub</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body style="background-color: <%= theme === 'dark' ? '#222' : '#f0f4f8' %>; color: <%= theme === 'dark' ? '#fff' : '#333' %>; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 0;">
    
    <div class="navbar" style="<%= theme === 'dark' ? 'background-color: #111;' : '' %>">
        <h2>WeebHub</h2>
        <div>
            <a href="/anime" style="color: white; margin-right: 15px;">Inapoi la colectie</a>
            <a href="/profil" style="color: white; margin-right: 15px; text-decoration: none; font-weight: bold;">👤 Profil</a>
            <a href="/logout" style="color: #ff4d4d;">Deconectare</a>
        </div>
    </div>

    <div style="max-width: 900px; margin: 50px auto; padding: 20px;">
        <div style="display: flex; flex-wrap: wrap; gap: 40px; background: <%= theme === 'dark' ? '#333' : 'white' %>; padding: 30px; border-radius: 12px; box-shadow: 0 8px 16px rgba(0,0,0,0.1);">
            
            <div style="flex: 1; min-width: 250px; text-align: center;">
                <img src="<%= anime.imagine %>" alt="<%= anime.titlu %>" style="width: 100%; max-width: 280px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.15);">
            </div>

            <div style="flex: 2; min-width: 300px;">
                <h1 style="margin-top: 0; color: <%= theme === 'dark' ? '#90e0ef' : '#023e8a' %>; font-size: 2.5em;"><%= anime.titlu %></h1>
                
                <div style="display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap;">
                    <span style="background-color: #0077b6; color: white; padding: 5px 12px; border-radius: 15px; font-weight: bold; font-size: 0.9em;"><%= anime.gen %></span>
                    <span style="background-color: #00b4d8; color: white; padding: 5px 12px; border-radius: 15px; font-weight: bold; font-size: 0.9em;"><%= anime.eps %> Episoade</span>
                    <span style="background-color: #f1c40f; color: #333; padding: 5px 12px; border-radius: 15px; font-weight: bold; font-size: 0.9em;">⭐ <%= anime.scor %> MAL Scor</span>
                </div>

                <h3 style="border-bottom: 2px solid <%= theme === 'dark' ? '#555' : '#eee' %>; padding-bottom: 5px; color: <%= theme === 'dark' ? '#90e0ef' : '#023e8a' %>;">Sinopsis / Descriere</h3>
                <p style="line-height: 1.6; color: <%= theme === 'dark' ? '#ccc' : '#555' %>; font-size: 1.1em;">
                    <%= anime.descriere %>
                </p>

                <div style="margin-top: 30px; display: flex; gap: 15px; flex-wrap: wrap;">
                    
                    <% if (isWatched) { %>
                        <button style="background-color: #2ecc71; color: white; padding: 10px 25px; border: none; border-radius: 5px; font-weight: bold; cursor: default;">✔️ Adaugat la Vizionate</button>
                    <% } else { %>
                        <form action="/anime/<%= anime.id %>/vizionat" method="POST" style="margin: 0;">
                            <button type="submit" style="background-color: #e67e22; color: white; padding: 10px 25px; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; transition: 0.3s;">➕ Adauga la Vizionate</button>
                        </form>
                    <% } %>

                    <a href="/anime" style="text-decoration: none;">
                        <button class="btn btn-login" style="width: auto; padding: 10px 25px;">Inapoi la Lista</button>
                    </a>
                </div>
                
            </div>

        </div>
    </div>

</body>
</html>