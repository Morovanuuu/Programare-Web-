<!DOCTYPE html>
<html>
<head>
    <title>Zona Protejata - WeebHub</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body style="background-color: <%= theme === 'dark' ? '#222' : '#f0f4f8' %>; color: <%= theme === 'dark' ? '#fff' : '#333' %>; transition: background-color 0.3s, color 0.3s; margin: 0;">
    
    <div class="navbar" style="<%= theme === 'dark' ? 'background-color: #111; box-shadow: 0 4px 6px rgba(255,255,255,0.05);' : '' %>">
        <h2>WeebHub</h2>
        <div style="display: flex; align-items: center; gap: 20px;">
            
            <a href="/toggle-theme" style="text-decoration: none;">
                <button style="background-color: <%= theme === 'dark' ? '#f1c40f' : '#2c3e50' %>; color: <%= theme === 'dark' ? '#333' : '#fff' %>; border: none; padding: 8px 15px; border-radius: 20px; cursor: pointer; font-weight: bold; transition: 0.3s;">
                    <%= theme === 'dark' ? '☀️ Light Mode' : '🌙 Dark Mode' %>
                </button>
            </a>

            <a href="/profil" style="color: white; font-weight: bold; text-decoration: none; display: flex; align-items: center; gap: 8px;">
                👤 <%= user.username %>
            </a>
            <a href="/logout" style="color: #ff4d4d;">Deconectare</a>
        </div>
    </div>

    <div style="display: flex; justify-content: center; margin-top: 40px;">
        <div class="card" style="width: 450px; <%= theme === 'dark' ? 'background: #333; color: white;' : '' %>">
            <h2 style="color: <%= theme === 'dark' ? '#90e0ef' : '#023e8a' %>; margin-top: 0; font-size: 1.5em;">Panoul Tau de Control</h2>
            <hr style="border-color: <%= theme === 'dark' ? '#555' : '#eee' %>; margin-bottom: 20px;">
            
            <div style="display: flex; justify-content: space-around;">
                <div>
                    <h3 style="margin: 0; font-size: 1.8em; color: <%= theme === 'dark' ? '#f1c40f' : '#2c3e50' %>;">
                        <%= theme === 'dark' ? '🌙' : '☀️' %>
                    </h3>
                    <p style="margin: 5px 0 0 0; color: #888; font-size: 0.9em;">Tema Activa</p>
                </div>

                <div>
                    <h3 style="margin: 0; font-size: 1.8em; color: <%= theme === 'dark' ? '#90e0ef' : '#0077b6' %>;"><%= views %></h3>
                    <p style="margin: 5px 0 0 0; color: #888; font-size: 0.9em;">Afisari pagina</p>
                </div>
            </div>
        </div>
    </div>

    <h2 style="text-align: center; margin-top: 50px; font-size: 2em; color: <%= theme === 'dark' ? '#fff' : '#333' %>;">Colectia de Anime</h2>
    
    <div style="display: flex; justify-content: center; gap: 15px; margin: 20px 0; flex-wrap: wrap; padding: 0 20px;">
        <a href="/anime?gen=all" style="text-decoration: none;">
            <button style="padding: 8px 16px; border-radius: 20px; border: none; font-weight: bold; cursor: pointer; background-color: <%= genActiv === 'all' ? '#0077b6' : '#ccc' %>; color: white; transition: 0.3s;">Toate</button>
        </a>
        <a href="/anime?gen=Action" style="text-decoration: none;">
            <button style="padding: 8px 16px; border-radius: 20px; border: none; font-weight: bold; cursor: pointer; background-color: <%= genActiv === 'Action' ? '#0077b6' : '#ccc' %>; color: white; transition: 0.3s;">Action</button>
        </a>
        <a href="/anime?gen=Comedy" style="text-decoration: none;">
            <button style="padding: 8px 16px; border-radius: 20px; border: none; font-weight: bold; cursor: pointer; background-color: <%= genActiv === 'Comedy' ? '#0077b6' : '#ccc' %>; color: white; transition: 0.3s;">Comedy</button>
        </a>
        <a href="/anime?gen=Fantasy" style="text-decoration: none;">
            <button style="padding: 8px 16px; border-radius: 20px; border: none; font-weight: bold; cursor: pointer; background-color: <%= genActiv === 'Fantasy' ? '#0077b6' : '#ccc' %>; color: white; transition: 0.3s;">Fantasy</button>
        </a>
        <a href="/anime?gen=Adventure" style="text-decoration: none;">
            <button style="padding: 8px 16px; border-radius: 20px; border: none; font-weight: bold; cursor: pointer; background-color: <%= genActiv === 'Adventure' ? '#0077b6' : '#ccc' %>; color: white; transition: 0.3s;">Adventure</button>
        </a>
        <a href="/anime?gen=Mystery" style="text-decoration: none;">
            <button style="padding: 8px 16px; border-radius: 20px; border: none; font-weight: bold; cursor: pointer; background-color: <%= genActiv === 'Mystery' ? '#0077b6' : '#ccc' %>; color: white; transition: 0.3s;">Mystery</button>
        </a>
    </div>

    <div style="display: flex; justify-content: center; margin-bottom: 30px; padding: 0 20px;">
        <form action="/anime" method="GET" style="display: flex; gap: 10px; width: 100%; max-width: 500px;">
            <input type="hidden" name="gen" value="<%= genActiv %>">
            
            <input type="text" name="search" placeholder="Cauta un anime dupa titlu..." value="<%= typeof searchTerm !== 'undefined' ? searchTerm : '' %>" style="flex: 1; padding: 12px 20px; border-radius: 25px; border: 2px solid <%= theme === 'dark' ? '#444' : '#ccc' %>; background-color: <%= theme === 'dark' ? '#222' : '#fff' %>; color: <%= theme === 'dark' ? '#fff' : '#333' %>; outline: none; font-size: 1em; transition: 0.3s;">
            
            <button type="submit" style="padding: 10px 25px; border-radius: 25px; border: none; background-color: #f1c40f; color: #333; font-weight: bold; cursor: pointer; font-size: 1em; transition: 0.3s;">Cauta 🔍</button>
            
            <% if (typeof searchTerm !== 'undefined' && searchTerm !== '') { %>
                <a href="/anime?gen=<%= genActiv %>" style="text-decoration: none; display: flex; align-items: center;">
                    <button type="button" style="padding: 10px 15px; border-radius: 25px; border: none; background-color: #e74c3c; color: white; font-weight: bold; cursor: pointer;">❌</button>
                </a>
            <% } %>
        </form>
    </div>

    <div class="anime-grid">
        <% animeList.forEach(function(a) { %>
            <div class="anime-card" style="<%= theme === 'dark' ? 'background: #333; color: white;' : '' %>">
                
                <img src="<%= a.imagine %>" alt="Poster <%= a.titlu %>" style="width: 100%; height: 300px; object-fit: cover;">
                
                <h3 style="<%= theme === 'dark' ? 'color: #90e0ef;' : '#023e8a' %>; margin-bottom: 5px;"><%= a.titlu %></h3>
                
                <p style="margin-top: 0; font-weight: bold; color: <%= theme === 'dark' ? '#fff' : '#333' %>;"><%= a.gen %> • <%= a.eps %> eps.</p>
                
                <a href="/anime/<%= a.id %>" style="text-decoration: none;">
                    <button class="btn btn-login" style="width: 80%; margin-bottom: 10px;">Vezi Detalii</button>
                </a>
            </div>
        <% }); %>
    </div>

</body>
</html>